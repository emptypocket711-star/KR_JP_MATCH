rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // ===== users/{uid} =====
    match /users/{uid} {
      allow read: if request.auth != null;

      allow create: if request.auth != null && request.auth.uid == uid
        && !request.resource.data.keys().hasAny([
          "quotaRemaining",
          "quotaResetAt",
          "extraQuotaPurchased",
          "isBanned",
          "reportCount",
          "uniqueReporterCount",
          "lastReportedAt",
          "bannedAt",
          "banReason"
        ]);

      allow update: if request.auth != null && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          "quotaRemaining",
          "quotaResetAt",
          "extraQuotaPurchased",
          "isBanned",
          "reportCount",
          "uniqueReporterCount",
          "lastReportedAt",
          "bannedAt",
          "banReason",
          "likeCount",
          "ratingSum",
          "ratingCount",
          "avgRating",
          "keyCount",
          "dailyKeyLimit"
        ]);

      // 다른 유저가 하트를 보낼 때 likeCount만 +1 허용
      allow update: if request.auth != null
        && request.auth.uid != uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount'])
        && request.resource.data.likeCount == resource.data.get('likeCount', 0) + 1;

      match /seen/{otherUid} {
        allow read, write: if false;
      }

      match /blocks/{otherUid} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      match /notifications/{notificationId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow update: if request.auth != null && request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["read"]);
        allow create, delete: if false;
      }
    }

    // ===== likes/{fromUid_toUid} =====
    // 클라이언트에서 직접 좋아요 처리 (Cloud Functions 미배포 환경)
    match /likes/{likeId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.fromUid
            || request.auth.uid == resource.data.toUid);
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.fromUid;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.fromUid;
    }

    // ===== matches/{matchId} =====
    match /matches/{matchId} {
      // resource == null: 문서가 없는 경우 존재 여부 확인 허용
      allow read: if request.auth != null
        && (resource == null || request.auth.uid in resource.data.userIds);

      // 매칭된 두 유저 중 한 명이 생성 가능
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.userIds;

      // 메시지 전송 등 업데이트 허용
      allow update: if request.auth != null
        && request.auth.uid in resource.data.userIds;

      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.userIds;
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.userIds
          && request.auth.uid == request.resource.data.senderId;
      }
    }

    // ===== posts/{postId} =====
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.uid;

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create, update, delete: if false;

        match /replies/{replyId} {
          allow read: if request.auth != null;
          allow create, update, delete: if false;
        }
      }
    }

    // ===== post_likes/{postId}/likes/{uid} =====
    match /post_likes/{postId}/likes/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ===== ratings/{ratingId} =====
    match /ratings/{ratingId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.raterUid
            || request.auth.uid == resource.data.ratedUid);
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.raterUid
        && request.resource.data.stars is int
        && request.resource.data.stars >= 1
        && request.resource.data.stars <= 5;
      allow update, delete: if false;
    }

    // ===== reports/{reportId} =====
    match /reports/{reportId} {
      allow read, write: if false;
    }

    // ===== reportCounters/{targetUid}/reporters/{reporterUid} =====
    match /reportCounters/{targetUid}/{document=**} {
      allow read, write: if false;
    }
  }
}
